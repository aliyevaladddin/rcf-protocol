# tree-sitter grammar packages publish mutually-incompatible peer ranges for
# the `tree-sitter` core (goâ†’^0.25, rustâ†’^0.22.1, typescriptâ†’^0.21). In semver
# 0.x these carets never intersect, so no single core version satisfies all
# three literally â€” yet the native N-API bindings are ABI-compatible across the
# whole 0.2x line. We pin the core at ^0.25 and accept the over-strict peer
# ranges here rather than scattering --legacy-peer-deps across CI and dev shells.
legacy-peer-deps=true
